{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeviceHub",
  "mainBinaryName": "DeviceHub",
  "version": "1.0.2",
  "identifier": "com.devicehub.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DeviceHub",
        "width": 1000,
        "height": 700,
        "minWidth": 960,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "binaries/*",
      "resources/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/hoangnv170752/adb-compass/main/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg2NUMyNTk3QkMwNkQ3NjAKUldSZzF3YThseVZjaG9LSEl5YW96Y3l5MzJKeDZabmF5c2V3UjNVVFBtUll1eUo5MnpiRjduaUoK"
    }
  }
}